      "code": "from openpyxl import Workbook\nfrom openpyxl.styles import Font, Alignment, Border, Side, PatternFill\nfrom openpyxl.utils import get_column_letter\n\ndef build_template(ws):\n    ws.title = \"業務発生明細サンプルリスト\"\n\n    # Column widths (A=1 through T=20)\n    col_widths = {\n        1: 2,    # spacer\n        2: 8,    # 物件コード\n        3: 10,   # 物件名\n        4: 6,    # 棟番号\n        5: 6,    # 部屋番号\n        6: 8,    # 契約者名\n        7: 6,    # 契約開始\n        8: 6,    # 契約終了\n        9: 8,    # 賃料\n        10: 6,   # 管理費\n        11: 6,   # 共益費\n        12: 6,   # 駐車場\n        13: 6,   # その他\n        14: 8,   # 合計賃料\n        15: 6,   # 敷金\n        16: 6,   # 礼金\n        17: 8,   # 仲介手数料\n        18: 8,   # 管理手数料\n        19: 8,   # 累計支払\n        20: 2,   # spacer\n    }\n    for col, width in col_widths.items():\n        ws.column_dimensions[get_column_letter(col)].width = width\n\n    # Row heights\n    row_heights = {\n        1: 20,\n        2: 20,\n        3: 30,\n        4: 30,\n        5: 20,\n        6: 20,\n        7: 20,\n        8: 20,\n        9: 20,\n        10: 20,\n        11: 20,\n        12: 20,\n        13: 20,\n        14: 20,\n        15: 20,\n        16: 20,\n        17: 20,\n        18: 20,\n        19: 20,\n        20: 20,\n        21: 20,\n        22: 20,\n        23: 20,\n        24: 20,\n        25: 20,\n        26: 20,\n        27: 20,\n        28: 20,\n        29: 20,\n        30: 20,\n        31: 20,\n        32: 20,\n        33: 20,\n        34: 20,\n        35: 20,\n        36: 20,\n        37: 20,\n        38: 20,\n        39: 20,\n        40: 20,\n        41: 20,\n        42: 20,\n        43: 20,\n        44: 20,\n        45: 20,\n        46: 20,\n        47: 20,\n        48: 20,\n        49: 20,\n        50: 20,\n    }\n    num_rows = 50\n    num_cols = 20\n    for r, h in row_heights.items():\n        ws.row_dimensions[r].height = h\n\n    # Step 2: Apply thin border to every cell\n    thin = Side(style='thin')\n    border = Border(top=thin, bottom=thin, left=thin, right=thin)\n    for row in ws.iter_rows(min_row=1, max_row=num_rows, min_col=1, max_col=num_cols):\n        for cell in row:\n            cell.border = border\n\n    # Step 3: Fills, values, fonts, alignment\n    gray_fill = PatternFill(fill_type=\"solid\", fgColor=\"BFBFBF\")\n    light_gray = PatternFill(fill_type=\"solid\", fgColor=\"D9D9D9\")\n    header_fill = PatternFill(fill_type=\"solid\", fgColor=\"808080\")\n\n    bold = Font(bold=True, size=9)\n    normal = Font(size=9)\n    center = Alignment(horizontal=\"center\", vertical=\"center\", wrap_text=True)\n    right = Alignment(horizontal=\"right\", vertical=\"center\")\n    left_align = Alignment(horizontal=\"left\", vertical=\"center\", wrap_text=True)\n\n    # Title row\n    ws.cell(row=1, column=2).value = \"業務発生明細サンプルリスト\"\n    ws.cell(row=1, column=2).font = Font(bold=True, size=12)\n    ws.cell(row=1, column=2).alignment = left_align\n\n    ws.cell(row=1, column=18).value = \"2026/6/25\"\n    ws.cell(row=1, column=18).font = normal\n    ws.cell(row=1, column=18).alignment = right\n\n    ws.cell(row=1, column=19).value = \"PAGE:1\"\n    ws.cell(row=1, column=19).font = normal\n    ws.cell(row=1, column=19).alignment = right\n\n    # Header labels row 2\n    headers_r2 = {\n        2: \"物件コード\",\n        3: \"物件名\",\n        4: \"棟\",\n        5: \"部屋番号\",\n        6: \"契約者名\",\n        7: \"契約\\n開始日\",\n        8: \"契約\\n終了日\",\n        9: \"賃料\",\n        10: \"管理費\",\n        11: \"共益費\",\n        12: \"駐車場\",\n        13: \"その他\",\n        14: \"合計賃料\",\n        15: \"敷金\",\n        16: \"礼金\",\n        17: \"仲介\\n手数料\",\n        18: \"管理\\n手数料\",\n        19: \"累計\\n支払額\",\n    }\n    for col, val in headers_r2.items():\n        cell = ws.cell(row=2, column=col)\n        cell.value = val\n        cell.font = bold\n        cell.alignment = center\n        cell.fill = gray_fill\n\n    # Sub-header row 3\n    sub_headers_r3 = {\n        2: \"物件コード\",\n        3: \"物件名\",\n        4: \"棟\",\n        5: \"部屋番号\",\n        6: \"契約者名\",\n        7: \"契約\\n開始日\",\n        8: \"契約\\n終了日\",\n        9: \"賃料\",\n        10: \"管理費\",\n        11: \"共益費\",\n        12: \"駐車場\",\n        13: \"その他\",\n        14: \"合計賃料\",\n        15: \"敷金\",\n        16: \"礼金\",\n        17: \"仲介\\n手数料\",\n        18: \"管理\\n手数料\",\n        19: \"累計\\n支払額\",\n    }\n    for col, val in sub_headers_r3.items():\n        cell = ws.cell(row=3, column=col)\n        cell.value = val\n        cell.font = bold\n        cell.alignment = center\n        cell.fill = light_gray\n\n    # Section labels (left side labels)\n    section_labels = {\n        4: (2, \"ぴったり\"),\n        5: (2, \"てんてん\"),\n        6: (2, \"さんさん\"),\n        7: (2, \"よんよん\"),\n        8: (2, \"ごごご\"),\n        9: (2, \"ろくろく\"),\n        10: (2, \"ななな\"),\n        11: (2, \"はちはち\"),\n        12: (2, \"きゅうきゅう\"),\n        13: (2, \"じゅうじゅう\"),\n    }\n\n    # Row labels for summary sections\n    summary_labels = [\n        \"先月末\",\n        \"当月末\",\n        \"前月比\",\n        \"先々月末\",\n        \"十月\",\n    ]\n\n    # Data area rows - alternating fills for readability\n    # (no fill for plain data rows)\n\n    # Summary section headers\n    summary_row_start = 40\n    summary_cols = {\n        2: \"先月末\",\n        3: \"当月末\",\n        4: \"前月比\",\n        5: \"先々月末\",\n        6: \"十月\",\n    }\n\n    # Left-side vertical labels\n    left_labels = {\n        4: \"ぴったり\",\n        10: \"てんてん\",\n        16: \"さんさん\",\n        22: \"よんよん\",\n        28: \"ごごご\",\n        34: \"ろくろく\",\n        40: \"ななな\",\n        46: \"はちはち\",\n    }\n\n    # Page setup\n    ws.page_setup.paperSize = 9\n    ws.page_setup.fitToPage = True\n    ws.page_setup.fitToWidth = 1\n    ws.page_setup.fitToHeight = 1\n    ws.page_setup.orientation = \"landscape\"\n    ws.page_margins.left = 0.5\n    ws.page_margins.right = 0.5\n    ws.page_margins.top = 0.5\n    ws.page_margins.bottom = 0.5\n\n    # Step 4: Merge cells (LAST)\n    ws.merge_cells(\"B1:Q1\")  # Title\n    ws.merge_cells(\"B2:B3\")\n    ws.merge_cells(\"C2:C3\")\n    ws.merge_cells(\"D2:D3\")\n    ws.merge_cells(\"E2:E3\")\n    ws.merge_cells(\"F2:F3\")\n    ws.merge_cells(\"G2:G3\")\n    ws.merge_cells(\"H2:H3\")\n    ws.merge_cells(\"I2:I3\")\n    ws.merge_cells(\"J2:J3\")\n    ws.merge_cells(\"K2:K3\")\n    ws.merge_cells(\"L2:L3\")\n    ws.merge_cells(\"M2:M3\")\n    ws.merge_cells(\"N2:N3\")\n    ws.merge_cells(\"O2:O3\")\n    ws.merge_cells(\"P2:P3\")\n    ws.merge_cells(\"Q2:Q3\")\n    ws.merge_cells(\"R2:R3\")\n    ws.merge_cells(\"S2:S3\")",
